generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id             String    @id @default(uuid()) @db.Uuid
  external_id    BigInt?   @unique
  name           String    @db.VarChar(255)
  iso_code       String?   @db.VarChar(5)
  image_path     String?
  last_synced_at DateTime?
  raw_payload    Json?

  leagues League[]
  teams   Team[]
  players Player[]

  @@map("countries")
}

model League {
  id               String    @id @default(uuid()) @db.Uuid
  external_id      BigInt?   @unique
  country_id       String?   @db.Uuid
  name             String    @db.VarChar(255)
  type             String?   @db.VarChar(50) // 'domestic', 'domestic_cup', 'international'
  image_path       String?
  has_premium_data Boolean   @default(false)
  priority_level   Int       @default(1000)
  last_synced_at   DateTime?
  raw_payload      Json?

  country  Country? @relation(fields: [country_id], references: [id])
  seasons  Season[]
  fixtures Fixture[]

  @@index([priority_level], name: "idx_league_priority")
  @@index([country_id], name: "idx_league_country")
  @@map("leagues")
}

model Season {
  id             String    @id @default(uuid()) @db.Uuid
  external_id    BigInt?   @unique
  league_id      String    @db.Uuid
  name           String    @db.VarChar(100)
  is_current     Boolean   @default(false)
  start_date     DateTime? @db.Date
  end_date       DateTime? @db.Date
  last_synced_at DateTime?
  raw_payload    Json?

  league    League     @relation(fields: [league_id], references: [id], onDelete: Cascade)
  fixtures  Fixture[]
  standings Standing[]

  @@index([league_id, is_current], name: "idx_seasons_current")
  @@map("seasons")
}

model Team {
  id             String    @id @default(uuid()) @db.Uuid
  external_id    BigInt?   @unique
  country_id     String?   @db.Uuid
  name           String    @db.VarChar(255)
  short_code     String?   @db.VarChar(10)
  image_path     String?
  founded        Int?
  venue_name     String?   @db.VarChar(255)
  last_synced_at DateTime?
  raw_payload    Json?

  country            Country?             @relation(fields: [country_id], references: [id])
  home_fixtures      Fixture[]            @relation("HomeTeam")
  away_fixtures      Fixture[]            @relation("AwayTeam")
  fixture_events     FixtureEvent[]
  fixture_statistics FixtureStatistic[]
  standings          Standing[]

  @@index([name], name: "idx_teams_name")
  @@map("teams")
}

model Player {
  id             String    @id @default(uuid()) @db.Uuid
  external_id    BigInt?   @unique
  country_id     String?   @db.Uuid
  display_name   String    @db.VarChar(255)
  image_path     String?
  position       String?   @db.VarChar(50)
  date_of_birth  DateTime? @db.Date
  last_synced_at DateTime?
  raw_payload    Json?

  country        Country?       @relation(fields: [country_id], references: [id])
  events         FixtureEvent[] @relation("EventPlayer")
  related_events FixtureEvent[] @relation("RelatedPlayer")

  @@index([display_name], name: "idx_players_name")
  @@map("players")
}

model Fixture {
  id                 String    @id @default(uuid()) @db.Uuid
  external_id        BigInt?   @unique
  season_id          String?   @db.Uuid
  league_id          String    @db.Uuid
  home_team_id       String    @db.Uuid
  away_team_id       String    @db.Uuid
  venue_id           BigInt?
  name               String?   @db.VarChar(255)
  starting_at        DateTime
  status             String    @db.VarChar(50)
  status_minute      Int?
  status_injury_time Int?
  home_score         Int       @default(0)
  away_score         Int       @default(0)
  leg                String?   @db.VarChar(50)
  has_premium_stats  Boolean   @default(false)
  last_synced_at     DateTime?
  raw_payload        Json?

  league    League  @relation(fields: [league_id], references: [id])
  season    Season? @relation(fields: [season_id], references: [id])
  home_team Team    @relation("HomeTeam", fields: [home_team_id], references: [id])
  away_team Team    @relation("AwayTeam", fields: [away_team_id], references: [id])

  events         FixtureEvent[]
  statistics     FixtureStatistic[]
  betting_posts  BettingPost[]
  delivery_logs  NotificationDeliveryLog[]

  @@index([starting_at], name: "idx_fixtures_starting_at")
  // Prisma doesn't support partial indexes natively yet, but we'd add `WHERE status = 'LIVE'` via raw SQL in migration.
  @@index([status], name: "idx_fixtures_status")
  @@index([league_id, starting_at], name: "idx_fixtures_league_date")
  @@map("fixtures")
}

model FixtureEvent {
  id                String  @id @default(uuid()) @db.Uuid
  external_id       BigInt? @unique
  fixture_id        String  @db.Uuid
  team_id           String? @db.Uuid
  player_id         String? @db.Uuid
  related_player_id String? @db.Uuid
  type              String  @db.VarChar(50)
  minute            Int
  extra_minute      Int?
  sort_order        Int
  result            String? @db.VarChar(255)
  is_var_reversed   Boolean @default(false)
  raw_payload       Json?

  fixture        Fixture @relation(fields: [fixture_id], references: [id], onDelete: Cascade)
  team           Team?   @relation(fields: [team_id], references: [id])
  player         Player? @relation("EventPlayer", fields: [player_id], references: [id])
  related_player Player? @relation("RelatedPlayer", fields: [related_player_id], references: [id])
  
  delivery_logs  NotificationDeliveryLog[]

  @@index([fixture_id, sort_order], name: "idx_fixture_events")
  @@map("fixture_events")
}

model FixtureStatistic {
  fixture_id String   @db.Uuid
  team_id    String   @db.Uuid
  type       String   @db.VarChar(100)
  value      Decimal?

  fixture Fixture @relation(fields: [fixture_id], references: [id])
  team    Team    @relation(fields: [team_id], references: [id])

  @@id([fixture_id, team_id, type])
  @@map("fixture_statistics")
}

model Standing {
  id               String  @id @default(uuid()) @db.Uuid
  season_id        String  @db.Uuid
  team_id          String  @db.Uuid
  position         Int
  points           Int
  matches_played   Int
  won              Int
  draw             Int
  lost             Int
  goals_scored     Int
  goals_conceded   Int
  goal_difference  Int
  result_state     String? @db.VarChar(100)

  season Season @relation(fields: [season_id], references: [id])
  team   Team   @relation(fields: [team_id], references: [id])

  @@index([season_id, position], name: "idx_standings_season")
  @@map("standings")
}

model NewsArticle {
  id                String   @id @default(uuid()) @db.Uuid
  source_url        String   @unique
  title             String   @db.VarChar(255)
  image_url         String?
  published_at      DateTime
  category          String?  @db.VarChar(100)
  ai_summary        String?  @db.Text
  ai_why_it_matters String?  @db.Text
  raw_content       String?  @db.Text
  created_at        DateTime @default(now())

  @@map("news_articles")
}

model BettingPost {
  id                     String    @id @default(uuid()) @db.Uuid
  fixture_id             String    @db.Uuid
  market                 String    @db.VarChar(100)
  pick                   String    @db.VarChar(100)
  odds                   Decimal
  confidence_level       Int
  is_premium             Boolean   @default(false)
  admin_reasoning        String?   @db.Text
  ai_explanation_summary String?   @db.Text
  status                 String    @default("published") @db.VarChar(50)
  result                 String?   @db.VarChar(50)
  published_at           DateTime?
  created_at             DateTime  @default(now())

  fixture Fixture @relation(fields: [fixture_id], references: [id])

  @@map("betting_posts")
}

model User {
  id                      String    @id @default(uuid()) @db.Uuid
  email                   String    @unique @db.VarChar(255)
  password_hash           String?   @db.VarChar(255)
  role                    String    @default("user") @db.VarChar(50)
  subscription_status     String    @default("free") @db.VarChar(50)
  subscription_expires_at DateTime?
  created_at              DateTime  @default(now())

  favorites UserFavorite[]

  @@map("users")
}

model UserFavorite {
  user_id     String @db.Uuid
  entity_type String @db.VarChar(50) // 'team', 'league', 'player', 'fixture'
  entity_id   String @db.Uuid

  user User @relation(fields: [user_id], references: [id])

  @@id([user_id, entity_type, entity_id])
  @@map("user_favorites")
}

model NotificationDeliveryLog {
  id              String   @id @default(uuid()) @db.Uuid
  fixture_id      String   @db.Uuid
  event_id        String   @db.Uuid
  type            String   @db.VarChar(50)
  dispatched_at   DateTime @default(now())
  recipient_count Int
  status          String   @db.VarChar(50)

  fixture Fixture      @relation(fields: [fixture_id], references: [id])
  event   FixtureEvent @relation(fields: [event_id], references: [id])

  @@map("notification_delivery_logs")
}

model SyncJobHealth {
  job_name           String    @id @db.VarChar(100)
  last_run_at        DateTime?
  last_success_at    DateTime?
  error_count        Int       @default(0)
  last_error_message String?   @db.Text

  @@map("sync_jobs_health")
}

model MatchInsight {
  id          String   @id @default(uuid()) @db.Uuid
  match_id    String   @db.Uuid
  insightType String   @db.VarChar(50) // PRE_MATCH, LIVE, POST_MATCH, TURNING_POINT
  content     String   @db.Text
  stats_used  Json
  created_at  DateTime @default(now())

  @@index([match_id, insightType])
  @@map("match_insights")
}

model FanMessage {
  id         String   @id @default(uuid()) @db.Uuid
  match_id   String   @db.Uuid
  user_id    String   @db.Uuid
  content    String   @db.Text
  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id])
  
  @@index([match_id, created_at])
  @@map("fan_messages")
}

model UserSanction {
  id          String    @id @default(uuid()) @db.Uuid
  user_id     String    @unique @db.Uuid
  muted_until DateTime?
  banned      Boolean   @default(false)
  reason      String?   @db.Text
  
  @@map("user_sanctions")
}
